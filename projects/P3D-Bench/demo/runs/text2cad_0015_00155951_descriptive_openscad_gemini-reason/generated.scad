// Parameters
base_thickness = 5;       // Thickness of the main shallow plate
arc_radius = 75;          // Radius of the arc path for the plate
arc_angle = 50;           // Angle from center to end tabs (degrees)
center_od = 35;           // Outer diameter of the central hub
center_id = 15;           // Inner diameter of the central through opening
end_od = 20;              // Outer diameter of the plate at the ends
collar_depth = 4;         // Depth of the underside annular collar
collar_od = 24;           // Outer diameter of the underside collar
tab_height = 25;          // Height from plate top to the center of the tab hole
tab_thickness = 8;        // Thickness of the end tabs
tab_hole_diameter = 10;   // Diameter of the through opening in the tabs
$fn = 100;                // Global resolution for smooth curves

// Modules for solid components
module base_plate() {
    step = 5; // Angular step for the arc hull
    linear_extrude(base_thickness) {
        // Central hub
        circle(d=center_od);
        // Arc-based outline generated by hulling overlapping circles along an arc path
        for(theta = [-arc_angle : step : arc_angle - step]) {
            hull() {
                translate([arc_radius*sin(theta), arc_radius*cos(theta) - arc_radius])
                    circle(d=end_od);
                translate([arc_radius*sin(theta+step), arc_radius*cos(theta+step) - arc_radius])
                    circle(d=end_od);
            }
        }
    }
}

module collar() {
    // Shallow annular collar on the underside
    // Slightly extended in height to ensure a manifold union with the base plate
    translate([0, 0, -collar_depth])
        cylinder(h=collar_depth + 0.1, d=collar_od);
}

module tab_shape() {
    // Single tab geometry, built at origin
    hull() {
        // Base of the tab (extended slightly down for manifold union)
        translate([0, 0, -0.1])
            cube([end_od, tab_thickness, 0.2], center=true);
        // Top rounded section
        translate([0, 0, tab_height])
            rotate([90, 0, 0])
                cylinder(h=tab_thickness, d=end_od, center=true);
    }
}

module tabs() {
    // Place a tab at both ends of the arc
    for (theta = [-arc_angle, arc_angle]) {
        // Position at the end of the arc, on top of the base plate
        translate([arc_radius*sin(theta), arc_radius*cos(theta) - arc_radius, base_thickness])
            // Rotate to align the tab perpendicular to the arc path
            rotate([0, 0, -theta])
                tab_shape();
    }
}

// Modules for subtractive operations (holes)
module central_hole() {
    // Cuts through both the base plate and the underside collar
    translate([0, 0, -collar_depth - 1])
        cylinder(h=base_thickness + collar_depth + 2, d=center_id);
}

module tab_holes() {
    // Through openings for both tabs
    for (theta = [-arc_angle, arc_angle]) {
        translate([arc_radius*sin(theta), arc_radius*cos(theta) - arc_radius, base_thickness + tab_height])
            rotate([0, 0, -theta])
                rotate([90, 0, 0])
                    // Extended cylinder to ensure clean cuts
                    cylinder(h=tab_thickness + 2, d=tab_hole_diameter, center=true);
    }
}

// Main Model Assembly
difference() {
    // Combine all solid bodies
    union() {
        base_plate();
        collar();
        tabs();
    }
    // Subtract all holes
    central_hole();
    tab_holes();
}